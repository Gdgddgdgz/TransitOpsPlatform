generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id         String @id @default(uuid()) @db.Uuid
  clerkOrgId String @unique @map("clerk_org_id")
  name       String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  drivers         Driver[]
  vehicles        Vehicle[]
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@map("organizations")
}

model User {
  id          String  @id @default(uuid()) @db.Uuid
  clerkUserId String? @unique @map("clerk_user_id")

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  name  String
  email String @unique

  role UserRole

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  driver Driver?

  createdTrips Trip[] @relation("TripCreator")

  createdMaintenanceLogs MaintenanceLog[] @relation("MaintenanceCreator")

  closedMaintenanceLogs MaintenanceLog[] @relation("MaintenanceCloser")

  fuelLogs FuelLog[]

  expenses Expense[]

  @@map("users")
}

model Driver {
  id String @id @default(uuid()) @db.Uuid

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  licenseNumber   String? @unique @map("license_number")
  licenseCategory String? @map("license_category")

  licenseExpiry DateTime? @map("license_expiry") @db.Date

  contactNumber String? @map("contact_number")

  safetyScore Decimal? @map("safety_score") @db.Decimal(5, 2)

  status DriverStatus @default(AVAILABLE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trips Trip[]

  @@map("drivers")
}

model Vehicle {
  id String @id @default(uuid()) @db.Uuid

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  registrationNumber String @unique @map("registration_number")

  model String?
  type  String?

  maxLoadCapacity Decimal? @map("max_load_capacity") @db.Decimal(10, 2)

  odometer Decimal? @db.Decimal(10, 2)

  acquisitionCost Decimal? @map("acquisition_cost") @db.Decimal(12, 2)

  status VehicleStatus @default(AVAILABLE)
  region String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@map("vehicles")
}

model Trip {
  id String @id @default(uuid()) @db.Uuid

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  tripNumber String @unique @map("trip_number")

  vehicleId String  @map("vehicle_id") @db.Uuid
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  driverId String @map("driver_id") @db.Uuid
  driver   Driver @relation(fields: [driverId], references: [id])

  source      String?
  destination String?

  cargoWeight Decimal? @map("cargo_weight") @db.Decimal(10, 2)

  plannedDistance Decimal? @map("planned_distance") @db.Decimal(10, 2)
  actualDistance  Decimal? @map("actual_distance") @db.Decimal(10, 2)

  startOdometer Decimal? @map("start_odometer") @db.Decimal(10, 2)
  endOdometer   Decimal? @map("end_odometer") @db.Decimal(10, 2)

  revenue Decimal? @db.Decimal(12, 2)

  status TripStatus @default(DRAFT)

  plannedStart DateTime? @map("planned_start")
  plannedEnd   DateTime? @map("planned_end")

  dispatchedAt DateTime? @map("dispatched_at")
  completedAt  DateTime? @map("completed_at")

  createdById String @map("created_by") @db.Uuid
  createdBy   User   @relation("TripCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  fuelLogs FuelLog[]
  expenses Expense[]

  @@map("trips")
}

model MaintenanceLog {
  id String @id @default(uuid()) @db.Uuid

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  vehicleId String  @map("vehicle_id") @db.Uuid
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  title       String?
  description String?

  cost Decimal? @db.Decimal(12, 2)

  status MaintenanceStatus @default(OPEN)

  openedAt DateTime? @map("opened_at")
  closedAt DateTime? @map("closed_at")

  createdById String @map("created_by") @db.Uuid
  createdBy   User   @relation("MaintenanceCreator", fields: [createdById], references: [id])

  closedById String? @map("closed_by") @db.Uuid
  closedBy   User?   @relation("MaintenanceCloser", fields: [closedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("maintenance_logs")
}

model FuelLog {
  id String @id @default(uuid()) @db.Uuid

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  vehicleId String  @map("vehicle_id") @db.Uuid
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  tripId String? @map("trip_id") @db.Uuid
  trip   Trip?   @relation(fields: [tripId], references: [id])

  liters Decimal @db.Decimal(10, 2)

  cost Decimal @db.Decimal(12, 2)

  fuelDate DateTime @map("fuel_date") @db.Date

  createdById String @map("created_by") @db.Uuid
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fuel_logs")
}

model Expense {
  id String @id @default(uuid()) @db.Uuid

  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])

  vehicleId String?  @map("vehicle_id") @db.Uuid
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  tripId String? @map("trip_id") @db.Uuid
  trip   Trip?   @relation(fields: [tripId], references: [id])

  category ExpenseCategory

  amount Decimal @db.Decimal(12, 2)

  description String?

  expenseDate DateTime @map("expense_date") @db.Date

  createdById String @map("created_by") @db.Uuid
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("expenses")
}

enum UserRole {
  FLEET_MANAGER
  DISPATCHER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
  ADMIN
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum ExpenseCategory {
  TOLL
  REPAIR
  INSURANCE
  OTHER
}
