// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
enum UserRole {
  ADMIN
  FLEET_MANAGER
  DISPATCHER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum ExpenseCategory {
  TOLL
  REPAIR
  INSURANCE
  OTHER
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  clerkOrgId  String   @unique @map("clerk_org_id")
  name        String

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users            User[]
  drivers          Driver[]
  vehicles         Vehicle[]
  trips            Trip[]
  maintenanceLogs  MaintenanceLog[]
  fuelLogs         FuelLog[]
  expenses         Expense[]

  @@map("organizations")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  clerkUserId     String   @unique @map("clerk_user_id")

  organizationId  String   @db.Uuid @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id])

  name            String
  email           String   @unique
  role            UserRole

  isActive        Boolean  @default(true) @map("is_active")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  driver Driver?

  createdTrips            Trip[]           @relation("TripCreator")
  createdMaintenanceLogs  MaintenanceLog[] @relation("MaintenanceCreator")
  closedMaintenanceLogs   MaintenanceLog[] @relation("MaintenanceCloser")
  fuelLogs                FuelLog[]
  expenses                Expense[]

  @@map("users")
}

model Driver {
  id               String @id @default(uuid()) @db.Uuid

  organizationId   String @db.Uuid @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id])

  userId           String @unique @db.Uuid @map("user_id")
  user             User @relation(fields: [userId], references: [id])

  licenseNumber    String? @unique @map("license_number")
  licenseCategory  String? @map("license_category")
  licenseExpiry    DateTime? @db.Date @map("license_expiry")

  contactNumber    String? @map("contact_number")

  safetyScore      Decimal? @db.Decimal(5,2) @map("safety_score")

  status           DriverStatus

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  trips Trip[]

  @@map("drivers")
}

model Vehicle {
  id                  String @id @default(uuid()) @db.Uuid

  organizationId      String @db.Uuid @map("organization_id")
  organization        Organization @relation(fields: [organizationId], references: [id])

  registrationNumber  String @unique @map("registration_number")

  model               String?
  type                String?

  maxLoadCapacity     Decimal? @db.Decimal(10,2) @map("max_load_capacity")

  odometer            Decimal? @db.Decimal(10,2)

  acquisitionCost     Decimal? @db.Decimal(12,2) @map("acquisition_cost")

  status              VehicleStatus

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  trips            Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs         FuelLog[]
  expenses         Expense[]

  @@map("vehicles")
}

model Trip {
  id                 String @id @default(uuid()) @db.Uuid

  organizationId     String @db.Uuid @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id])

  tripNumber         String @unique @map("trip_number")

  vehicleId          String @db.Uuid @map("vehicle_id")
  vehicle            Vehicle @relation(fields: [vehicleId], references: [id])

  driverId           String @db.Uuid @map("driver_id")
  driver             Driver @relation(fields: [driverId], references: [id])

  source             String?
  destination        String?

  cargoWeight        Decimal? @db.Decimal(10,2) @map("cargo_weight")

  plannedDistance    Decimal? @db.Decimal(10,2) @map("planned_distance")
  actualDistance     Decimal? @db.Decimal(10,2) @map("actual_distance")

  startOdometer      Decimal? @db.Decimal(10,2) @map("start_odometer")
  endOdometer        Decimal? @db.Decimal(10,2) @map("end_odometer")

  revenue            Decimal? @db.Decimal(12,2)

  status             TripStatus

  plannedStart       DateTime? @map("planned_start")
  plannedEnd         DateTime? @map("planned_end")

  dispatchedAt       DateTime? @map("dispatched_at")
  completedAt        DateTime? @map("completed_at")

  createdById        String @db.Uuid @map("created_by")
  createdBy          User @relation("TripCreator", fields: [createdById], references: [id])

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  fuelLogs FuelLog[]
  expenses Expense[]

  @@map("trips")
}

model MaintenanceLog {
  id               String @id @default(uuid()) @db.Uuid

  organizationId   String @db.Uuid @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id])

  vehicleId        String @db.Uuid @map("vehicle_id")
  vehicle          Vehicle @relation(fields: [vehicleId], references: [id])

  title            String?
  description      String?

  cost             Decimal? @db.Decimal(12,2)

  status           MaintenanceStatus

  openedAt         DateTime? @map("opened_at")
  closedAt         DateTime? @map("closed_at")

  createdById      String @db.Uuid @map("created_by")
  createdBy        User @relation("MaintenanceCreator", fields: [createdById], references: [id])

  closedById       String? @db.Uuid @map("closed_by")
  closedBy         User? @relation("MaintenanceCloser", fields: [closedById], references: [id])

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("maintenance_logs")
}

model FuelLog {
  id               String @id @default(uuid()) @db.Uuid

  organizationId   String @db.Uuid @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id])

  vehicleId        String @db.Uuid @map("vehicle_id")
  vehicle          Vehicle @relation(fields: [vehicleId], references: [id])

  tripId           String? @db.Uuid @map("trip_id")
  trip             Trip? @relation(fields: [tripId], references: [id])

  liters           Decimal @db.Decimal(10,2)
  cost             Decimal @db.Decimal(12,2)

  fuelDate         DateTime @db.Date @map("fuel_date")

  createdById      String @db.Uuid @map("created_by")
  createdBy        User @relation(fields: [createdById], references: [id])

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("fuel_logs")
}

model Expense {
  id               String @id @default(uuid()) @db.Uuid

  organizationId   String @db.Uuid @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id])

  vehicleId        String? @db.Uuid @map("vehicle_id")
  vehicle          Vehicle? @relation(fields: [vehicleId], references: [id])

  tripId           String? @db.Uuid @map("trip_id")
  trip             Trip? @relation(fields: [tripId], references: [id])

  category         ExpenseCategory

  amount           Decimal @db.Decimal(12,2)

  description      String?

  expenseDate      DateTime @db.Date @map("expense_date")

  createdById      String @db.Uuid @map("created_by")
  createdBy        User @relation(fields: [createdById], references: [id])

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("expenses")
}